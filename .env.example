# ============================================================
# Odin — Personal AI Business Agent Platform
# Root .env.example  (copy to backend/.env and frontend/.env.local)
# ============================================================

# ---------- Core ----------
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO

# ---------- Supabase ----------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret from Supabase project settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ---------- Database (direct Postgres, for migrations / pgvector) ----------
DATABASE_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---------- Anthropic (Claude) ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
DEFAULT_MODEL=claude-sonnet-4-6

# ---------- OpenAI chat (agent brain when a GPT model is selected) ----------
# The agent brain can run on Claude OR OpenAI per-user (chosen in "My Agent").
# This sets the default OpenAI chat model id used for those users.
OPENAI_CHAT_MODEL=gpt-4o

# ---------- Embeddings ----------
# provider: openai | voyage
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
OPENAI_API_KEY=sk-xxxxxxxx
VOYAGE_API_KEY=

# ---------- Encryption (Fernet, AES-256) ----------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_ID_PRO=price_xxxxxxxx
STRIPE_PRICE_ID_BUSINESS=price_xxxxxxxx

# ---------- Twilio (WhatsApp) ----------
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------- Telegram ----------
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret

# ---------- Connector OAuth ----------
# Airtable
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=
AIRTABLE_REDIRECT_URI=http://localhost:8000/api/connectors/airtable/callback

# Google (Drive + Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/connectors/google/callback

# Microsoft (Outlook + Excel Online)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/connectors/microsoft/callback
MICROSOFT_TENANT=common

# ---------- App URLs ----------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ---------- Superadmin ----------
SUPERADMIN_EMAILS=admin@example.com

# ============================================================
# Frontend-only (prefix NEXT_PUBLIC_ for browser exposure)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
